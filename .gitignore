#
# .gitignore — Ignored files and directories
# 2026-04-17
#
# Single source of truth for everything Git should never track.
# Organized by concern so new patterns land in the right section.
#
#   Node / Vue / Vite
#   Build / cache
#   Logs
#   Test / coverage
#   Environment / secrets
#   Editors / IDEs
#   OS junk
#   Temp / backup
#   Local-only contributor files
#
# Requirements:
# package-lock.json is tracked on purpose (npm ci needs it)
# .env.example is the only tracked env file
#
# Cristian D. Moreno (Kyonax)
# kyonax.corp@gmail.com

# ── Node / Vue / Vite ────────────────────────────────────────
node_modules/
dist/
dist-ssr/
.vite/
*.local

# ── Build / cache ────────────────────────────────────────────
.cache/
.parcel-cache/
.turbo/
.next/
.nuxt/
.svelte-kit/
.output/
.sass-cache/
.eslintcache
.stylelintcache
.prettiercache

# ── Logs ─────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── Test / coverage ──────────────────────────────────────────
coverage/
.nyc_output/
*.lcov

# ── Environment / secrets ────────────────────────────────────
.env
.env.local
.env.*.local
.env.*
!.env.example
*.pem
*.key
*.crt
*.cert
*.pfx
*.p12
id_rsa
id_rsa.*
id_dsa
id_dsa.*
id_ed25519
id_ed25519.*
known_hosts
secrets/
credentials/
.secrets/
.aws/
.gcloud/
auth.json
.rc
.rc.gpg
*.gpg
*.jks
*.keystore
*.token
*.secret
.htpasswd
.npmrc
.yarnrc
*.sqlite
*.db
*.sql
.ssh/

# ── Editors / IDEs ───────────────────────────────────────────
.vscode/
.idea/
*.iml
*.swp
*.swo
*~
\#*\#
.\#*
.claude/
.aider*

# ── OS junk ──────────────────────────────────────────────────
.DS_Store
.DS_Store?
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
.fseventsd
.DocumentRevisions-V100
.TemporaryItems
.VolumeIcon.icns
Thumbs.db
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/

# ── Temp / backup ────────────────────────────────────────────
*.bak
*.orig
*.tmp
*.temp
tmp/
temp/

# ── Local-only contributor files ─────────────────────────────
.github/BRANCHES.org
CLAUDE.md
COMMIT.org
PR.org
